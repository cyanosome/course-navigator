# 共通タイムゾーン
TZ=Asia/Tokyo

# ルーティングに使用するドメイン
# プロキシ側 (proxy/.env) の DOMAIN 設定と一致させてください。
# ローカル開発時: cource-navigator.localhost
# 本番デプロイ時: yourdomain.com
DOMAIN=cource-navigator.localhost

# Database connection settings (for backend)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=coursenavigator
DB_USER=admin
DB_PASSWORD=secure_password_please_change
